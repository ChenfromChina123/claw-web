# ============================================================
# 开发环境配置
# ============================================================

# API 基础地址（留空则使用相对路径 /api）
VITE_API_BASE_URL=

# 是否启用 PTY Shell（连接后端真实终端）
# 开发环境：true（默认开启）
# 生产环境：false（默认关闭，见 .env.production）
VITE_FEATURE_PTY_SHELL=true

# 强制覆盖"开发模式"判断（正常情况不需要设置）
# VITE_DEV_MODE=true
