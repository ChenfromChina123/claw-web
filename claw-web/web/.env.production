# ============================================================
# 生产环境配置
# ============================================================

# API 基础地址（留空则使用相对路径 /api）
VITE_API_BASE_URL=

# 是否启用 PTY Shell（连接后端真实终端）
# 生产环境默认禁用（PTY 涉及 shell 执行权限，安全起见在生产环境关闭）
VITE_FEATURE_PTY_SHELL=false

# 强制覆盖"开发模式"判断（正常情况不需要设置）
# VITE_DEV_MODE=false
