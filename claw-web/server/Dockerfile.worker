# Claw-Web - Worker 容器 Dockerfile（单用户隔离模式）
#
# 优化特性：
# ✅ 轻量化设计：专为单用户场景优化
# ✅ 内存优化：降低V8堆内存和线程池大小
# ✅ 快速启动：精简依赖和初始化流程
# ✅ 健康检查：支持容器编排器的健康探测
#
# 安全加固：
# ✅ Worker 不连接数据库 - 所有 DB 操作由 Master 负责
# ✅ 使用 MASTER_INTERNAL_TOKEN 验证 Master 请求
# ✅ 禁止容器内提权和网络攻击
#
# 使用场景：
# - 作为容器池中的Worker实例
# - 每个容器只服务一个用户
# - 由Master服务统一调度和管理

FROM oven/bun:1 AS worker

LABEL maintainer="Claude Code HAHA Team"
LABEL description="Worker container for single-user isolation"
LABEL version="1.0.0"
LABEL role="worker"

# 使用国内镜像源加速
RUN if [ -f /etc/apt/sources.list.d/debian.sources ]; then \
        sed -i 's|http://deb.debian.org/debian|http://mirrors.aliyun.com/debian|g' /etc/apt/sources.list.d/debian.sources && \
        sed -i 's|http://security.debian.org/debian-security|http://mirrors.aliyun.com/debian-security|g' /etc/apt/sources.list.d/debian.sources; \
    elif [ -f /etc/apt/sources.list ]; then \
        sed -i 's|http://deb.debian.org/debian|http://mirrors.aliyun.com/debian|g' /etc/apt/sources.list && \
        sed -i 's|http://security.debian.org/debian-security|http://mirrors.aliyun.com/debian-security|g' /etc/apt/sources.list; \
    fi

# 安装系统依赖（移除 MySQL 客户端 - Worker 不需要数据库连接）
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    tzdata \
    supervisor \
    procps \
    net-tools \
    git \
    python3 \
    python3-pip \
    && ln -sf /usr/share/zoneinfo/Asia/Shanghai /etc/localtime \
    && echo "Asia/Shanghai" > /etc/timezone \
    && rm -rf /var/lib/apt/lists/* \
    && rm -rf /var/cache/apt/archives/*

WORKDIR /app

# 复制依赖文件并安装（利用Docker缓存层）
COPY server/package.json ./

# 使用国内镜像源加速
ENV BUN_CONFIG_REGISTRY=https://registry.npmmirror.com
RUN bun install --production --registry=https://registry.npmmirror.com

# 复制源代码
COPY server/ .

# 复制 Supervisor 主配置文件
COPY server/config/supervisord.conf /etc/supervisor/supervisord.conf

# 清理环境变量文件（防止覆盖docker-compose设置）
RUN rm -f .env .env.local .env.*.local 2>/dev/null || true && \
    echo "# Environment variables set by container orchestrator" > .env

# 设置环境变量（针对单用户优化的配置）
# 安全说明：
# - CONTAINER_ROLE=worker 表示这是 Worker 容器
# - DB_* 变量已被移除，Worker 不连接数据库
# - MASTER_INTERNAL_TOKEN 用于验证 Master 的内部 API 请求
# - WORKSPACE_BASE_DIR=/workspace 是 Bind Mount 挂载点
ENV NODE_ENV=production \
    PORT=3000 \
    # Bind Mount 挂载点（宿主机目录挂载到容器内的路径）
    WORKSPACE_BASE_DIR=/workspace \
    TZ=Asia/Shanghai \
    # 内存优化：单用户降低内存占用
    NODE_OPTIONS="--max-old-space-size=256" \
    # 线程池优化：单用户减少并发线程
    UV_THREADPOOL_SIZE=2 \
    # 租户隔离配置
    TENANT_ISOLATION_ENABLED=true \
    MAX_USERS=1 \
    USER_STORAGE_QUOTA_MB=200 \
    USER_SESSION_LIMIT=5 \
    USER_PTY_LIMIT=2 \
    MAX_FILE_SIZE_MB=10 \
    MAX_FILES_PER_USER=500 \
    API_TIMEOUT_MS=300000 \
    CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1 \
    DISABLE_TELEMETRY=1 \
    # 容器标识 - Worker 模式
    CONTAINER_ROLE=worker \
    # 禁用数据库连接（安全加固）
    DB_HOST="" \
    DB_PORT="" \
    DB_USER="" \
    DB_PASSWORD="" \
    DB_NAME=""

# 创建工作区目录结构（作为 Bind Mount 挂载点）
RUN mkdir -p /workspace \
             /app/logs \
             /etc/supervisor/conf.d \
             /var/log/supervisor \
    && chown -R bun:bun /workspace /app/logs

# 暴露端口
EXPOSE 3000

# 健康检查（更频繁的检查间隔，便于编排器快速发现故障）
HEALTHCHECK --interval=15s --timeout=5s --start-period=10s --retries=3 \
    CMD curl -f http://localhost:3000/api/health || exit 1

# 停止信号（优雅关闭）
STOPSIGNAL SIGINT

# 启动命令（使用非 root 用户运行 - 安全加固）
# 注意：容器启动时需要确保 /app/workspaces 目录存在且可访问
# Worker 模式入口文件：index.ts（自动检测 CONTAINER_ROLE）
USER bun

CMD ["bun", "--bun", "run", "src/index.ts"]
