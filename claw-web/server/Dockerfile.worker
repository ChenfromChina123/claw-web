# Claw-Web - Worker 容器 Dockerfile（单用户隔离模式）
#
# 优化特性：
# ✅ 轻量化设计：专为单用户场景优化
# ✅ 内存优化：降低V8堆内存和线程池大小
# ✅ 快速启动：精简依赖和初始化流程
# ✅ 健康检查：支持容器编排器的健康探测
# ✅ 开发工具预装：Python、Node.js、Git、GitHub CLI 等
#
# 使用场景：
# - 作为容器池中的Worker实例
# - 每个容器只服务一个用户
# - 由Master服务统一调度和管理

FROM oven/bun:1 AS worker

LABEL maintainer="Claude Code HAHA Team"
LABEL description="Worker container for single-user isolation"
LABEL version="1.0.0"
LABEL role="worker"

# 使用国内镜像源加速
RUN sed -i 's|http://deb.debian.org/debian|http://mirrors.aliyun.com/debian|g' /etc/apt/sources.list.d/debian.sources && \
    sed -i 's|http://security.debian.org/debian-security|http://mirrors.aliyun.com/debian-security|g' /etc/apt/sources.list.d/debian.sources

# 安装系统依赖和进程管理器
RUN apt-get update && apt-get install -y --no-install-recommends \
    default-mysql-client \
    curl \
    tzdata \
    supervisor \
    procps \
    net-tools \
    # Python 依赖
    python3-pip \
    build-essential \
    zlib1g-dev \
    libncurses5-dev \
    libgdbm-dev \
    libnss3-dev \
    libssl-dev \
    libreadline-dev \
    libffi-dev \
    libsqlite3-dev \
    wget \
    llvm \
    liblapack-dev \
    gfortran \
    # Git 依赖
    liberror-perl \
    # GitHub CLI 依赖
    gnupg \
    && ln -sf /usr/share/zoneinfo/Asia/Shanghai /etc/localtime \
    && echo "Asia/Shanghai" > /etc/timezone \
    && rm -rf /var/lib/apt/lists/* \
    && rm -rf /var/cache/apt/archives/* \
    && apt-get clean \
    && rm -rf /tmp/* /var/tmp/*

# ==================== 安装 Python 3.11.0 ====================
RUN cd /tmp && \
    wget https://www.python.org/ftp/python/3.11.0/Python-3.11.0.tgz && \
    tar -xf Python-3.11.0.tgz && \
    cd Python-3.11.0 && \
    ./configure --enable-optimizations --prefix=/usr/local && \
    make -j$(nproc) && \
    make altinstall && \
    cd / && \
    rm -rf /tmp/Python-3.11.0*

# 验证 Python 安装
RUN python3.11 --version && pip3 --version

# ==================== 安装 Node.js 22.13.0 ====================
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - && \
    apt-get install -y nodejs && \
    node --version && \
    npm --version

# ==================== 安装 pnpm 9.4.0 ====================
RUN npm install -g pnpm@9.4.0 && pnpm --version

# ==================== 安装 Git（使用 apt-get） ====================
RUN apt-get update && apt-get install -y git && \
    git --version

# ==================== 安装 GitHub CLI (gh) 2.40.1 ====================
# 使用官方脚本安装
RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg && \
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" | tee /etc/apt/sources.list.d/github-cli.list > /dev/null && \
    apt-get update && \
    apt-get install -y gh && \
    gh --version

# ==================== 安装 PM2 ====================
RUN npm install -g pm2 && pm2 --version

WORKDIR /app

# 复制依赖文件并安装（利用Docker缓存层）
COPY server/package.json ./

# 使用国内镜像源加速
ENV BUN_CONFIG_REGISTRY=https://registry.npmmirror.com
RUN bun install --production

# 复制源代码
COPY server/ .

# 复制 Supervisor 主配置文件
COPY server/config/supervisord.conf /etc/supervisor/supervisord.conf

# 清理环境变量文件（防止覆盖docker-compose设置）
RUN rm -f .env .env.local .env.*.local 2>/dev/null || true && \
    echo "# Environment variables set by container orchestrator" > .env

# 设置环境变量（针对单用户优化的配置）
ENV NODE_ENV=production \
    PORT=3000 \
    WORKSPACE_BASE_DIR=/app/workspaces \
    TZ=Asia/Shanghai \
    # Python 环境
    PATH="/usr/local/bin:$PATH" \
    # 内存优化：单用户降低内存占用
    NODE_OPTIONS="--max-old-space-size=256" \
    # 线程池优化：单用户减少并发线程
    UV_THREADPOOL_SIZE=2 \
    # 租户隔离配置
    TENANT_ISOLATION_ENABLED=true \
    MAX_USERS=1 \
    USER_STORAGE_QUOTA_MB=200 \
    USER_SESSION_LIMIT=5 \
    USER_PTY_LIMIT=2 \
    MAX_FILE_SIZE_MB=10 \
    MAX_FILES_PER_USER=500 \
    API_TIMEOUT_MS=300000 \
    CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1 \
    DISABLE_TELEMETRY=1 \
    # 容器标识
    CONTAINER_ROLE=worker

# 创建工作区目录结构、Supervisor 配置目录和日志目录
RUN mkdir -p /app/workspaces/users \
             /app/workspaces/sessions \
             /app/workspaces/projects \
             /app/logs \
             /etc/supervisor/conf.d \
             /var/log/supervisor \
    && chown -R bun:bun /app/workspaces /app/logs

# 暴露端口
EXPOSE 3000

# 健康检查（更频繁的检查间隔，便于编排器快速发现故障）
HEALTHCHECK --interval=15s --timeout=5s --start-period=10s --retries=3 \
    CMD curl -f http://localhost:3000/api/health || exit 1

# 停止信号（优雅关闭）
STOPSIGNAL SIGINT

# 启动命令（使用root用户运行，确保可以绑定端口）
CMD ["bun", "--bun", "run", "src/index.ts"]
