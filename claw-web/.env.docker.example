# ===========================================
# Claude Code HAHA - Docker 生产环境配置
# ===========================================
#
# 使用说明：
# 1. 复制此文件为 .env：cp .env.docker.example .env
# 2. 填写以下配置项（必须修改的已标注 ⚠️）
# 3. 运行：docker-compose up -d
#
# 安全提醒：
# - ⚠️ 请务必修改所有密码和密钥
# - 不要将 .env 文件提交到版本控制
# - 定期轮换密钥

# ==================== API 配置 ====================

# ⚠️ Anthropic API 密钥（必填）
ANTHROPIC_AUTH_TOKEN=your_anthropic_api_key_here

# API 基础 URL（可选，默认使用官方）
ANTHROPIC_BASE_URL=https://api.anthropic.com

# 模型配置（可选）
ANTHROPIC_DEFAULT_HAIKU_MODEL=claude-3-haiku-20240307
ANTHROPIC_DEFAULT_OPUS_MODEL=claude-3-opus-20240229
ANTHROPIC_DEFAULT_SONNET_MODEL=claude-3-sonnet-20240229

# API 超时时间（毫秒）- AI 任务可能需要较长时间
API_TIMEOUT_MS=300000

# ==================== 数据库配置 ====================

# 数据库主机名（Docker 内部使用服务名）
DB_HOST=mysql

# 数据库端口
DB_PORT=3306

# ⚠️ 数据库用户名
DB_USER=claude_user

# ⚠️ 数据库密码（请使用强密码！）
DB_PASSWORD=your_secure_database_password_here_2024

# 数据库名称
DB_NAME=claude_code_haha

# 外部访问端口（可选，用于本地调试）
DB_EXTERNAL_PORT=3306

# ==================== Redis 配置（可选） ====================

# Redis 端口
REDIS_PORT=6379

# Redis 密码（可选）
# REDIS_PASSWORD=

# ==================== JWT 认证配置 ====================

# ⚠️ JWT 密钥（至少 32 个字符，用于签名 token）
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars-!!!

# Token 过期时间
JWT_EXPIRATION=24h

# ==================== 邮件配置（可选，不填则使用开发模式） ====================

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.com

# ==================== 服务端口配置 ====================

# 后端服务端口
PORT=3000

# 前端服务端口
FRONTEND_PORT=80

# ==================== ⭐ 多租户隔离配置（核心功能）====================

# 是否启用多租户隔离（true/false）
TENANT_ISOLATION_ENABLED=true

# 最大用户数
MAX_USERS=100

# 每个用户的存储配额（MB）
USER_STORAGE_QUOTA_MB=500

# 每个用户最大会话数
USER_SESSION_LIMIT=10

# 每个用户最大 PTY 终端进程数
USER_PTY_LIMIT=5

# 单个文件最大大小（MB）
MAX_FILE_SIZE_MB=10

# 每个用户最大文件数量
MAX_FILES_PER_USER=1000

# ==================== 性能优化配置 ====================

# 禁用非必要网络流量
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1

# 禁用遥测数据收集
DISABLE_TELEMETRY=1

# ==================== 日志配置（可选） ====================

# 日志级别（debug, info, warn, error）
LOG_LEVEL=info
