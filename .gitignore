# ==================== 环境变量配置 ====================
# 敏感环境变量文件（如 .env, .env.local 等）不提交
.env
.env.local
.env.*.local

# 允许提交示例文件（不含敏感数据）
!.env.example

# Web 前端环境文件（保留在 web 目录）
web/.env.*
!web/.env.example

# ==================== Node.js ====================
node_modules/
dist/
build/
.npm
.yarn
.pnp.*

# ==================== 依赖目录 ====================
server/node_modules/
web/node_modules/

# ==================== IDE ====================
.vscode/
.idea/
*.swp
*.swo
*~

# ==================== OS ====================
.DS_Store
Thumbs.db

# ==================== 日志 ====================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ==================== 测试覆盖率 ====================
coverage/
.nyc_output/

# ==================== 工作空间数据 ====================
workspaces/
/data/
