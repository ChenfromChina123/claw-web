# ==================== 环境变量配置 ====================
# 敏感环境变量文件（如 .env, .env.local 等）不提交
.env
.env.local
.env.*.local

# 允许提交示例文件（不含敏感数据）
!.env.example

# Web 前端环境文件（保留在 web 目录）
web/.env.*
!web/.env.example

# ==================== Node.js ====================
node_modules/
dist/
build/
.npm
.yarn
.pnp.*

# ==================== 依赖目录 ====================
server/node_modules/
web/node_modules/

# ==================== 构建产物（大文件，不上传）====================
# 前端打包输出
web/dist/
web/build/

# 服务端打包输出
server/dist/

# Docker 镜像导出文件（通常几百MB到几GB）
*.tar
*.tar.gz
*.zip

# Docker 镜像相关（二进制文件，极大）
*.image
*.img
docker-image-*

# IDE 和编辑器
.vscode/
.idea/
*.swp
*.swo
*~

# ==================== OS ====================
.DS_Store
Thumbs.db

# ==================== 日志 ====================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ==================== 测试覆盖率 ====================
coverage/
.nyc_output/

# ==================== 工作空间数据 ====================
workspaces/
/data/

# ==================== Docker 相关 ====================
# Docker 体积数据（避免提交容器层缓存）
.docker/

# ==================== 数据库备份和转储 ====================
*.sql.bak
*.sql.dump
*.db
*.sqlite
*.sqlite3

# ==================== 性能分析和调试文件 ====================
*.prof
*.cpuprofile
heapdump-*
core.*

# ==================== 临时文件和缓存 ====================
.tmp/
temp/
cache/
*.tmp
*.temp
*.bak
*.backup
*.swp
*.swo
*~
