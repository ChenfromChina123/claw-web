# ==================== Claw-Web 环境变量配置模板 ====================
# 
# 复制此文件为 .env 并根据实际情况修改：
#   cp env.example .env
#
# ⚠️ 安全提醒：生产环境请务必修改所有密码和密钥！

# ==================== MySQL 数据库配置 ====================
MYSQL_ROOT_PASSWORD=your_mysql_root_password_here
MYSQL_DATABASE=claw_web
MYSQL_USER=clawuser
MYSQL_PASSWORD=your_mysql_password_here
# 建议修改默认端口避免冲突
MYSQL_PORT=23306

# ==================== Master 服务配置 ====================
# Master API 端口（前端访问）
MASTER_PORT=13000

# JWT 认证配置（必须修改！）
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# ==================== LLM API 配置（二选一）====================

# 选项1: Anthropic Claude（需要付费 API Key）
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=https://api.anthropic.com

# 选项2: 阿里云通义千问（推荐，有免费额度）
# 获取地址: https://bailian.console.aliyun.com/
QWEN_API_KEY=sk-your-qwen-api-key-here
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# LLM 模型选择
# 可选值: anthropic, qwen
LLM_PROVIDER=qwen

# 模型名称:
# - anthropic: claude-sonnet-4-20250514, claude-opus-4-20250514, claude-3-5-sonnet-20241022
# - qwen: qwen-plus, qwen-turbo, qwen-max, qwen-long
LLM_MODEL=qwen-plus

# ==================== Worker 容器池配置 ====================
# 最小热备容器数
CONTAINER_POOL_MIN_SIZE=1
# 最大容器数
CONTAINER_POOL_MAX_SIZE=5
# 空闲超时时间（毫秒），0 表示永不回收
CONTAINER_IDLE_TIMEOUT_MS=0
# Worker 容器基础端口
CONTAINER_BASE_PORT=3100

# Master-Worker 内部通信 Token（必须保持一致！）
MASTER_INTERNAL_TOKEN=your_internal_token_here

# ==================== 前端服务配置 ====================
FRONTEND_PORT=80

# ==================== 监控与运维配置 ====================
# 磁盘使用警告阈值（%）
DISK_WARNING_THRESHOLD=80
# 磁盘使用危险阈值（%）
DISK_CRITICAL_THRESHOLD=90
# 是否启用 Docker 自动清理
ENABLE_DOCKER_AUTO_CLEANUP=true

# PTY 终端配置（生产模式启用）
PTY_ENABLED=true

# ==================== SMTP 邮件服务配置（可选）====================
# 配置后可发送验证码邮件，否则验证码仅输出到日志
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@qq.com
SMTP_PASS=your_smtp_password
SMTP_FROM="Claw-Code <your_email@qq.com>"
