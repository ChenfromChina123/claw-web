<?xml version="1.0" encoding="utf-8"?>
<!-- 网络安全配置：开发环境允许所有明文HTTP流量 -->
<network-security-config>
    <!-- 基础配置：允许所有明文流量（仅用于开发环境） -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>
</network-security-config>
