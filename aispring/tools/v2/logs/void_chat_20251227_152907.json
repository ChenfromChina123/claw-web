      "400: def update_game(self):",
      "401:     \"\"\"更新游戏逻辑\"\"\"",
      "402:     current_time = pygame.time.get_ticks()",
      "403: ",
      "404:     # 检查特殊食物是否过期",
      "405:     if self.special_food and current_time - self.special_food_timer > self.special_food_duration * 1000:",
      "406:         self.special_food = None",
      "407: ",
      "408:     # 检查是否到了移动时间",
      "409:     if current_time - self.last_move_time < self.game_speed:",
      "410:         return",
      "411: ",
      "412:     self.last_move_time = current_time",
      "413: ",
      "414:     # 更新方向",
      "415:     self.direction = self.next_direction",
      "416: ",
      "417:     # 获取蛇头",
      "418:     head = self.snake[0].copy()",
      "419: ",
      "420:     # 根据方向移动蛇头",
      "421:     if self.direction == Direction.UP:",
      "422:         head['y'] -=1",
      "423:     elif self.direction == Direction.DOWN:",
      "424:         head['y'] +=1",
      "425:     elif self.direction == Direction.LEFT:",
      "426:         head['x'] -=1",
      "427:     elif self.direction == Direction.RIGHT:",
      "428:         head['x'] +=1",
      "429: ",
      "430:     # 检查是否撞墙",
      "431:     if (head['x'] <0 or head['x'] >= self.grid_width or ",
      "432:         head['y'] <0 or head['y'] >= self.grid_height):",
      "433:         self.game_over()",
      "434:         return",
      "435: ",
      "436:     # 检查是否撞到自己",
      "437:     for segment in self.snake:",
      "438:         if head['x'] == segment['x'] and head['y'] == segment['y']:",
      "439:             self.game_over()",
      "440:             return",
      "441: ",
      "442:     # 将新头部添加到蛇",
      "443:     self.snake.insert(0, head)",
      "444: ",
      "445:     # 检查是否吃到普通食物",
      "446:     if self.food and head['x'] == self.food['x'] and head['y'] == self.food['y']:",
      "447:         self.score +=10",
      "448:         if self.score > self.high_score:",
      "449:             self.high_score = self.score",
      "450:             self.save_high_score()",
      "451:         self.generate_food()",
      "452:     # 检查是否吃到特殊食物",
      "453:     elif self.special_food and head['x'] == self.special_food['x'] and head['y'] == self.special_food['y']:",
      "454:         self.score +=50  # 特殊食物加分更多",
      "455:         if self.score > self.high_score:",
      "456:             self.high_score = self.score",
      "457:             self.save_high_score()",
      "458:         self.special_food = None",
