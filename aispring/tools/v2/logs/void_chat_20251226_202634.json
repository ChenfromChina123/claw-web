      "233:             tasks = self._stack_parser(full_reply)",
      "234: ",
      "235:             # 核心修改1：只要解析不到任务，直接退出循环",
      "236:             if not tasks:",
      "237:                 tool_keywords = [\"write\", \"read\", \"run\", \"command\", \"file\"]",
