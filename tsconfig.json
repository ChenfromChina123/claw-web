{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@ant/claude-for-chrome-mcp": [
        "./stubs/ant-claude-for-chrome-mcp.ts"
      ],
      "color-diff-napi": [
        "./stubs/color-diff-napi.ts"
      ],
      "src/*": [
        "./src/*"
      ]
    },
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "web",
    "web/dist",
    "server",
    "**/*.js",
    "src/commands",
    "src"
  ]
}
