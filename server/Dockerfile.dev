# Claude Code HAHA - 后端开发环境 Dockerfile（热重载模式）
#
# 特性：
# ✅ Bun --watch 文件变化自动重启
# ✅ TypeScript 直接运行（无需编译）
# ✅ 开发友好：源码挂载到容器内

FROM oven/bun:1-alpine

# 安装必要的系统依赖
RUN apk add --no-cache \
    mysql-client \
    curl \
    tzdata \
    bash \
    && cp /usr/share/zoneinfo/Asia/Shanghai /etc/localtime \
    && echo "Asia/Shanghai" > /etc/timezone \
    && rm -rf /var/cache/apk/*

WORKDIR /app

# 复制依赖文件（先复制，利用 Docker 缓存）
COPY server/package.json server/bun.lock ./

# 安装依赖
RUN bun install --frozen-lockfile

# 复制源代码
COPY server/ .

# 创建仅含注释的 .env（防止 Bun 报错，且不覆盖环境变量）
RUN echo "# Docker environment variables are set via docker-compose" > .env

# 暴露端口
EXPOSE 3000

# 热重载启动命令（--watch 监听文件变化自动重启）
CMD ["bun", "run", "--watch", "src/index.ts"]
