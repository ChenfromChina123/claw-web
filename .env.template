# ============================================================
# 环境变量配置模板
# 复制此文件为 .env 并填写实际值
# ============================================================

# ==================== 数据库配置 ====================
DB_ROOT_PASSWORD=your_secure_root_password_here
DB_NAME=aispring
DB_USER=aispring
DB_PASSWORD=your_secure_db_password_here
MYSQL_PORT=3306

# ==================== Redis 配置 ====================
REDIS_PORT=6379

# ==================== 端口映射 ====================
BACKEND_PORT=5000
FRONTEND_PORT=3000
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ==================== JWT 配置 ====================
JWT_SECRET_KEY=your_super_secret_key_at_least_32_characters_long
JWT_SECRET=your_jwt_secret_for_claude_code

# ==================== DeepSeek API (阿里百炼) ====================
DEEPSEEK_API_KEY=sk-your_deepseek_api_key_here
DEEPSEEK_URL=https://dashscope.aliyuncs.com/compatible-mode

# ==================== Anthropic API (Claude Code) ====================
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here
ANTHROPIC_AUTH_TOKEN=your_auth_token_here
ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic

# ==================== Jasypt 加密密码 ====================
JASYPT_PASSWORD=aistudy_secret_production

# ==================== 邮件配置 ====================
SENDER_EMAIL=your_email@qq.com
SENDER_PASSWORD=your_email_authorization_code

# ==================== 多用户隔离配置 ====================
# 用户 ID（用于容器命名和端口隔离）
USER_ID=default
