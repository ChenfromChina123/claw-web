# ==================== Claw-Web Docker 环境变量配置 ====================
# 
# 使用说明：
# 1. 复制此文件为 .env: cp .env.example .env
# 2. 根据实际环境修改配置值
# 3. 启动服务: docker-compose up -d
#
# ⚠️ 安全提醒：生产环境请务必修改所有密码和密钥！

# ==================== MySQL 数据库配置 ====================
MYSQL_ROOT_PASSWORD=your_mysql_root_password
MYSQL_DATABASE=claw_web
MYSQL_USER=clawuser
MYSQL_PASSWORD=your_mysql_password
MYSQL_PORT=3306

# ==================== Master 服务配置 ====================
MASTER_PORT=3000

# JWT 认证配置
JWT_SECRET=your-jwt-secret-key-generate-with-openssl-rand-base64-32
JWT_EXPIRES_IN=7d

# Anthropic API 配置（用于 AI Agent 功能）
ANTHROPIC_AUTH_TOKEN=your-anthropic-api-key
ANTHROPIC_BASE_URL=https://api.anthropic.com

# ==================== Worker 容器池配置 ====================
CONTAINER_POOL_MIN_SIZE=3
CONTAINER_POOL_MAX_SIZE=10
CONTAINER_IDLE_TIMEOUT_MS=300000
CONTAINER_BASE_PORT=3100

# Master-Worker 内部通信 Token（必须保持一致！）
MASTER_INTERNAL_TOKEN=your-master-worker-token-generate-with-openssl-rand-hex-32

# ==================== 前端服务配置 ====================
FRONTEND_PORT=80

# Worker 模板端口（调试用，默认不暴露）
WORKER_TEMPLATE_PORT=

# ==================== 监控与运维配置 ====================
DISK_WARNING_THRESHOLD=80
DISK_CRITICAL_THRESHOLD=90
ENABLE_DOCKER_AUTO_CLEANUP=true

# ==================== 开发模式配置（可选）====================
# NODE_ENV=development
# DEBUG=true
